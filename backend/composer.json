{
  "name": "fixit/auth-api",
  "description": "FixIt authentication API",
  "type": "project",
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "ext-fileinfo": "*",
    "firebase/php-jwt": "^7.0",
    "slim/psr7": "^1.7",
    "slim/slim": "^4.14",
    "stripe/stripe-php": "^20.3"
  },
  "autoload": {
    "psr-4": { "FixIt\\": "src/", "App\\": "src/App/" }
  },
  "scripts": {
    "serve": "php -S 127.0.0.1:8090 -t public public/index.php",
    "serve:lan": "php -S 0.0.0.0:8090 -t public public/index.php"
  }
}
